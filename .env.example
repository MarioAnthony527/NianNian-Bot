NEXT_PUBLIC_APP_URL=https://your-vercel-domain.vercel.app

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_VERIFICATION_TOKEN=xxx
# Only set this if you enabled Feishu "Encrypt Key" in 加密策略.
FEISHU_ENCRYPT_KEY=

LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-xxx
LLM_MODEL_ANALYZE=gpt-4o-mini
LLM_MODEL_COPY=gpt-4o-mini

# Optional. If your team has a working Douyin parser service, expose a GET endpoint that accepts ?url=.
DOUYIN_PARSER_BASE_URL=

# Used by /demo and detail pages for one-click push.
DEMO_SECRET=demo-local
